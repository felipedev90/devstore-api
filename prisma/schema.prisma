// Instrui o Prisma a gerar o client TS. É esse client que vai importar no código para fazer queries no banco;
generator client {
  provider = "prisma-client-js"
}

// Diz pro prisma qual banco usar e como conectar. O env("DATABASE_URL") lê a variavel de ambiente que já configurei no .env;
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id            String    @id @default(uuid())
  slug          String    @unique
  name          String
  description   String
  price         Float
  originalPrice Float?
  images        String[]
  category      String
  tags          String[]
  rating        Float      @default(0)
  reviewCount   Int        @default(0)
  stock         Int
  features      String[]
  createdAt     DateTime   @default(now())
  OrderItems    OrderItem[]
}

model User {
  id          String    @id @default(uuid())
  name        String
  email       String    @unique
  password    String
  createdAt   DateTime  @default(now())
  orders      Order[]
}

model Order {
  id          String @id @default(uuid())
  userId      String
  user        User @relation(fields: [userId], references: [id])
  items       OrderItem[]
  createdAt   DateTime @default(now())
}

model OrderItem {
  id          String @id @default(uuid())
  orderId     String
  productId   String
  quantity    Int
  price       Float
  order       Order @relation(fields: [orderId], references: [id])
  product     Product @relation(fields: [productId], references: [id])
}